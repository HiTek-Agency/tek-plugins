{
  "id": "my-plugin",
  "name": "My Plugin",
  "version": "0.1.0",
  "description": "A template Tek plugin — replace with your description",
  "entryPoint": "dist/index.js",
  "permissions": ["tools", "config"],
  "configSchema": [
    {
      "key": "exampleSetting",
      "label": "Example Setting",
      "type": "string",
